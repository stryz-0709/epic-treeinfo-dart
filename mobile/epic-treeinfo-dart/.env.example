# Copy this file to .env and fill in your values for local development.
# Mobile artifacts MUST NOT include privileged server-side credentials.

# Backend-for-Frontend API base URL
BACKEND_BASE_URL=http://localhost:8000

# Supabase public client access only (anon key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# EarthRanger password-grant auth is disabled by default for mobile security.
# Do not include ER_USERNAME / ER_PASSWORD in mobile env files.
ER_PASSWORD_GRANT_ENABLED=false

# Optional (only used when ER_PASSWORD_GRANT_ENABLED=true):
# must be HTTPS and host must be in ER_OAUTH_ALLOWED_HOSTS.
ER_OAUTH_TOKEN_URL=https://epictech.pamdas.org/oauth2/token/
ER_OAUTH_ALLOWED_HOSTS=epictech.pamdas.org
