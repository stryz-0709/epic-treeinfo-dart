+    body = await request.body()
+
+    if not _verify_signature(body, x_hub_signature_256):
+        raise HTTPException(status_code=401, detail="Invalid signature")
+
+    try:
+        payload = json.loads(body)
+    except json.JSONDecodeError:
+        raise HTTPException(status_code=400, detail="Invalid JSON")
+
+    log.info(
+        "Webhook: action=%s type=%s",
+        payload.get("action", "?"),
+        payload.get("event", {}).get("event_type", "?"),
+    )
+
+    event = payload.get("event") or payload
+
+    if not should_notify(event):
+        return JSONResponse({"status": "filtered"})
+
+    message = format_er_alert(event)
+    sent = send_to_zalo_group(message)
+    return JSONResponse({"status": "sent" if sent else "send_failed"})
