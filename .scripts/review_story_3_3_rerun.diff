+def _verify_signature(payload: bytes, signature: str | None) -> bool:
+    s = get_settings()
+    if not s.webhook_secret:
+        # Development mode may skip signature checks.
+        # Production mode must always enforce signature verification.
+        return not s.is_production
+    if not signature:
+        return False
+    expected = hmac.new(
+        s.webhook_secret.encode(), payload, hashlib.sha256
+    ).hexdigest()
+    return hmac.compare_digest(f"sha256={expected}", signature)
+
