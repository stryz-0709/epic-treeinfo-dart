# ─────────────────────────────────────────────────────────────
# EarthRanger Tree Pipeline — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── EarthRanger API ──────────────────────────────────────────
EARTHRANGER_DOMAIN=epictech.pamdas.org
EARTHRANGER_TOKEN=your-earthranger-api-token

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# ── Dashboard Auth ───────────────────────────────────────────
# Secret key for signing session cookies.
# In production use at least 32 random characters
# (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SESSION_SECRET=change-me-to-a-random-string
# Default admin password (only used on first run to create users.json)
DEFAULT_ADMIN_PASSWORD=admin123

# ── Mobile Auth ─────────────────────────────────────────────
# Access token time-to-live in minutes.
MOBILE_ACCESS_TOKEN_TTL_MINUTES=15
# Refresh/session token time-to-live in days.
MOBILE_REFRESH_TOKEN_TTL_DAYS=7

# ── Mobile API Performance Guardrails ───────────────────────
# Runtime max page sizes (defensive cap beyond endpoint defaults).
MOBILE_WORK_MANAGEMENT_MAX_PAGE_SIZE=366
MOBILE_INCIDENTS_MAX_PAGE_SIZE=200
MOBILE_SCHEDULES_MAX_PAGE_SIZE=500
# Max allowed date window (`from`..`to`) for mobile list/summary endpoints.
MOBILE_QUERY_MAX_WINDOW_DAYS=366
# Max allowed age for incremental `updated_since` checkpoint queries.
MOBILE_UPDATED_SINCE_MAX_AGE_DAYS=3650
# Emit warning logs when request duration exceeds this threshold (milliseconds).
MOBILE_SLOW_REQUEST_WARN_MS=1200
# Legacy alias (optional): overrides MOBILE_SLOW_REQUEST_WARN_MS when provided.
# REQUEST_SLOW_THRESHOLD_MS=750

# ── Runtime Environment ──────────────────────────────────────
# Allowed values: development, dev, staging, test, production, prod.
# Use "production" for hardened server mode.
ENVIRONMENT=development

# ── Zalo Notifications ───────────────────────────────────────
ZALO_ENABLED=true
ZALO_GROUP_ID=your-zalo-group-id
ZALO_APP_ID=your-app-id
ZALO_SECRET_KEY=your-secret-key

# Google Sheet for Zalo token storage
ZALO_SHEET_URL=https://docs.google.com/spreadsheets/d/your-sheet-id
ZALO_SHEET_TAB=APIKeys
ZALO_GET_OA_URL=https://openapi.zalo.me/v2.0/oa/getoa
ZALO_REFRESH_URL=https://oauth.zaloapp.com/v4/oa/access_token
ZALO_SERVICE_ACCOUNT_FILE=service-account.json

# ── Sync Pipeline ────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=60
SYNC_MAX_RETRIES=3
SYNC_RETRY_DELAY_SEC=30

# ── Retention & Compliance ───────────────────────────────────
RETENTION_ENABLED=true
RETENTION_SCHEDULE_TIMEZONE=Asia/Ho_Chi_Minh
RETENTION_SCHEDULE_HOUR_LOCAL=1
RETENTION_SCHEDULE_MINUTE_LOCAL=30
# Minimum retention window for ranger operational stats (>= 6 months).
RETENTION_MIN_DAYS=183
RETENTION_SOURCE_TABLE=daily_checkins
RETENTION_SOURCE_DAY_FIELD=day_key
RETENTION_AUDIT_TABLE=retention_job_runs
RETENTION_AUDIT_MEMORY_LIMIT=500

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
# Set to false for colorized dev output instead of JSON logs
LOG_JSON=true

# ── CORS (for NFC app / external clients) ────────────────────
# JSON array of allowed origins.
# In production, wildcard (*) is forbidden.
CORS_ORIGINS=["http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_API=60/minute
RATE_LIMIT_SYNC=2/minute
